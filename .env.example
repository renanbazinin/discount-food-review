# Copy to .env and fill in real values. .env is gitignored.
# Create the database user in Atlas → Database Access, then allowlist your dev IP in Atlas → Network Access.
# A dedicated app user with read/write on the `food-ranking` database is preferable to reusing an atlasAdmin user.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.rsn8ez5.mongodb.net/food-ranking?retryWrites=true&w=majority&appName=Cluster0
